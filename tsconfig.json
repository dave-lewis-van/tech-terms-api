{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "rootDir": "./scripts",
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": ["scripts/**/*", "src/**/*"]
}